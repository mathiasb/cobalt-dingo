# cobalt-dingo environment configuration.
#
# Two distinct Fortnox connected apps are configured here, one per mode.
# FORTNOX_MODE selects which credential set + token file is used at runtime;
# Taskfile targets set it explicitly so a forgotten env var cannot route a
# command to the wrong Fortnox company.
#
# Copy this file to .env and fill in real values. .env is gitignored.

# ── Fortnox mode ────────────────────────────────────────────────────────────
#
# Selected automatically by `task <target>` targets (mcp:sandbox sets
# sandbox, mcp:real-ro sets real_readonly, etc). When running a binary
# directly with `go run`, set this manually:
#
#   sandbox        — write-capable; for development against the Fortnox sandbox
#   real_readonly  — read-only against the live Fortnox; defense-in-depth gate
#                    refuses non-GET requests locally on top of OAuth scope
#
# Reserved for a future milestone:
#   real_readwrite — to be added when "AI drafts, you approve" write tools land

FORTNOX_MODE=

# ── Sandbox connected app ───────────────────────────────────────────────────
# Register a separate connected app in the Fortnox developer portal pointing
# at the sandbox. This app SHOULD have full scopes since seed/teardown writes.

FORTNOX_SANDBOX_CLIENT_ID=
FORTNOX_SANDBOX_CLIENT_SECRET=
FORTNOX_SANDBOX_REDIRECT_URI=http://localhost:8080/callback
FORTNOX_SANDBOX_SCOPES="companyinformation bookkeeping customer invoice supplier supplierinvoice payment currency project costcenter assets settings"
FORTNOX_SANDBOX_INVOICE_INBOX=

# ── Real (read-only) connected app ──────────────────────────────────────────
# Register a SECOND connected app pointing at your live Fortnox company.
# Configure it with READ-ONLY scopes only. Even if cobalt-dingo's local gate
# fails open by accident, Fortnox itself will refuse writes at the API
# gateway. Belt and braces.
#
# Read-only scopes (drop any *write* permissions in the Fortnox portal):
#   companyinformation, bookkeeping, customer, invoice, supplier,
#   supplierinvoice, project, costcenter, assets, settings, currency

FORTNOX_REAL_RO_CLIENT_ID=
FORTNOX_REAL_RO_CLIENT_SECRET=
FORTNOX_REAL_RO_REDIRECT_URI=http://localhost:8080/callback
FORTNOX_REAL_RO_SCOPES="companyinformation bookkeeping customer invoice supplier supplierinvoice project costcenter assets settings currency"
FORTNOX_REAL_RO_INVOICE_INBOX=

# ── Application ─────────────────────────────────────────────────────────────

PORT=8080
DATABASE_URL=

# ── Debtor (PAIN.001 batch generator) ───────────────────────────────────────

COBALT_DEBTOR_NAME=
COBALT_DEBTOR_IBAN=
COBALT_DEBTOR_BIC=

# ── Claude API (chat UI) ────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
